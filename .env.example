# Hammer Claw Command Center — environment template.
# Copy to .env.local for local dev, or set these in Vercel project settings.
# NEVER commit a real .env. Real secrets live in Vercel env vars only.

# --- GitHub (vault access) — account is sicnarf1232 ---
# Fine-grained PAT scoped to the vault repo only, Contents: Read and write.
GITHUB_TOKEN=
VAULT_REPO=sicnarf1232/hammer-claw-vault
VAULT_BRANCH=main
# Optional: the vault repo root folder name inside the repo, if notes are nested.
# Leave blank if markdown lives at the repo root.
VAULT_ROOT=

# --- Webhook auth (Phase 1) ---
# Shared secret. Power Automate Flow A sends it in X-HC-Signature; the app
# compares in constant time. Generate a long random string.
HC_WEBHOOK_SECRET=

# --- Power Automate (Phase 2) ---
# Flow B "When an HTTP request is received" trigger URL. Contains a SAS token,
# treat the whole URL as a secret. Leave blank until the flow exists.
POWER_AUTOMATE_REPLY_URL=

# --- Database (Phase 1+) ---
# Vercel Postgres (Neon) connection string. Pooled URL is fine for serverless.
POSTGRES_URL=

# --- Auth (single user) ---
# Shared password gate enforced in middleware. Alternatively use Vercel
# password protection and leave this blank.
APP_PASSWORD=

# --- AI (Phase 2 drafting, Phase 4 briefs) ---
ANTHROPIC_API_KEY=
# Model override (optional). Defaults to claude-sonnet-4-6.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Cron auth (Phase 4) ---
# Vercel sets CRON_SECRET automatically for Vercel Cron. Set the same value here
# for local testing of cron routes. Cron routes reject requests without it.
CRON_SECRET=

# --- App config ---
# Outlook folder name that triggers Flow A. Default ToHC.
TOHC_FOLDER=ToHC
# IANA timezone for date math and brief scheduling.
APP_TIMEZONE=America/Denver
